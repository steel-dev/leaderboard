---
import Layout from "../../../layouts/Layout.astro";
import {
  benchmarks,
  benchmarkDomainLabels,
  categoryColors,
  categoryRouteLabels,
  categorySlugs,
  getBenchmarkAnchorId,
  getBenchmarkPath,
  getCategoryPath,
} from "../../../lib/benchmarks";

export function getStaticPaths() {
  return benchmarks.map((benchmark) => ({
    params: { benchmark: getBenchmarkAnchorId(benchmark.name) },
    props: { benchmark },
  }));
}

const { benchmark } = Astro.props;

const pagePath = getBenchmarkPath(benchmark.name);
const categoryHasRoute = benchmark.category in categorySlugs;
const categoryPath = categoryHasRoute
  ? getCategoryPath(benchmark.category as keyof typeof categorySlugs)
  : `/registry#${getBenchmarkAnchorId(benchmark.name)}`;
const categoryLabel = categoryHasRoute
  ? categoryRouteLabels[benchmark.category as keyof typeof categoryRouteLabels]
  : benchmarkDomainLabels[benchmark.category];

const pageTitle = `${benchmark.name} benchmark | ${benchmarkDomainLabels[benchmark.category]} agent evaluation | Steel.dev`;
const pageDescription = `${benchmark.name} is a ${benchmark.selfHosted ? "self-hosted" : "public"} ${benchmarkDomainLabels[benchmark.category].toLowerCase()} benchmark. Compare its evaluation method, task count, top model score, human baseline, and source links.`;

const benchmarkSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Thing",
  name: benchmark.name,
  description: benchmark.description,
  url: `https://leaderboard.steel.dev${pagePath}`,
  category: benchmark.category,
  ...(benchmark.benchmarkOrg
    ? {
        creator: {
          "@type": "Organization",
          name: benchmark.benchmarkOrg,
        },
      }
    : {}),
  sameAs: [benchmark.paper, benchmark.github].filter(Boolean),
});

const breadcrumbSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Registry",
      item: "https://leaderboard.steel.dev/registry",
    },
    {
      "@type": "ListItem",
      position: 2,
      name: categoryLabel,
      item: `https://leaderboard.steel.dev${categoryPath}`,
    },
    {
      "@type": "ListItem",
      position: 3,
      name: benchmark.name,
      item: `https://leaderboard.steel.dev${pagePath}`,
    },
  ],
});
---

<Layout title={pageTitle} description={pageDescription} structuredData={[benchmarkSchema, breadcrumbSchema]}>
  <div class="w-full max-w-4xl">
    <nav aria-label="Breadcrumb" class="mb-6 text-xs font-mono uppercase tracking-widest text-dim">
      <a href="/registry" class="hover:text-accent transition-colors">Registry</a>
      <span class="mx-2">/</span>
      <a href={categoryPath} class="hover:text-accent transition-colors">{categoryLabel}</a>
      <span class="mx-2">/</span>
      <span class="text-text">{benchmark.name}</span>
    </nav>

    <div class="mb-8">
      <div class="text-[10px] font-mono tracking-widest uppercase mb-2">
        <span
          style={`color: ${benchmark.category === "WEB NAV" ? "var(--color-accent)" : categoryColors[benchmark.category]}`}
        >
          {benchmarkDomainLabels[benchmark.category]} benchmark
        </span>
        <span class="text-dim"> - {benchmark.selfHosted ? "Self-hosted" : "Public"}</span>
      </div>
      <h1 class="text-2xl md:text-4xl font-sans tracking-tight text-text mb-3">{benchmark.name}</h1>
      <p class="text-left font-sans md:text-lg text-dim">{benchmark.description}</p>
    </div>
  </div>

  <section class="w-full max-w-4xl font-mono border border-text border-opacity-30">
    <div class="bg-[var(--color-text)] p-[0.62rem] flex w-full items-center gap-[0.62rem]">
      <div class="bg-text text-black font-bold">BENCHMARK</div>
      <div class="flex flex-col gap-1 flex-1">
        {[0, 1, 2, 3, 4].map(() => <div class="bg-black h-[0.0625rem] w-full" />)}
      </div>
    </div>

    <div class="grid gap-6 px-4 py-4 md:grid-cols-[1.3fr_0.9fr]">
      <div class="space-y-3">
        {benchmark.benchmarkOrg && (
          <div class="text-dim text-[10px] uppercase tracking-widest">
            Benchmark by {benchmark.benchmarkOrg}
          </div>
        )}
        <dl class="grid gap-2 text-sm leading-relaxed">
          <div>
            <dt class="inline text-dim">Benchmark type:</dt>{" "}
            <dd class="inline text-text">
              {benchmark.selfHosted ? "Self-hosted benchmark" : "Public benchmark"}
            </dd>
          </div>
          <div>
            <dt class="inline text-dim">Benchmark domain:</dt>{" "}
            <dd class="inline text-text">{benchmarkDomainLabels[benchmark.category]}</dd>
          </div>
          <div>
            <dt class="inline text-dim">Task count:</dt>{" "}
            <dd class="inline text-text">{benchmark.tasks}</dd>
          </div>
          <div>
            <dt class="inline text-dim">Evaluation method:</dt>{" "}
            <dd class="inline text-text">{benchmark.evaluator}</dd>
          </div>
        </dl>
      </div>

      <dl class="grid gap-3 md:text-right">
        <div>
          <dt class="text-dim text-[10px] uppercase tracking-widest mb-0.5">Top model score</dt>
          <dd class="text-text font-bold text-lg">{benchmark.topScore}</dd>
          <div class="text-dim text-[10px]">{benchmark.topAgent}</div>
          <div class="text-dim text-[10px]">{benchmark.topOrg}</div>
        </div>
        <div>
          <dt class="text-dim text-[10px] uppercase tracking-widest mb-0.5">Human score</dt>
          <dd class="text-dim">{benchmark.human}</dd>
        </div>
      </dl>
    </div>

    <div class="border-t border-text border-opacity-10 px-4 py-4">
      <div class="grid gap-3 text-xs font-mono md:grid-cols-2">
        <a
          href={benchmark.paper}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex min-w-0 items-center justify-center border border-text border-opacity-20 px-2 py-1 text-center leading-tight text-dim hover:text-accent hover:border-accent transition-colors"
        >
          View {benchmark.name} benchmark paper
        </a>
        {benchmark.github && (
          <a
            href={benchmark.github}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex min-w-0 items-center justify-center border border-text border-opacity-20 px-2 py-1 text-center leading-tight text-dim hover:text-accent hover:border-accent transition-colors"
          >
            {benchmark.name} GitHub repository
          </a>
        )}
      </div>
    </div>
  </section>

  <section class="w-full max-w-4xl mt-8 border border-text border-opacity-30 p-4 md:p-5">
    <h2 class="text-base md:text-lg font-sans tracking-tight text-text mb-2">
      Where this benchmark fits
    </h2>
    <p class="text-sm md:text-[15px] leading-relaxed text-dim">
      Use this page when you need the benchmark-specific context. For side-by-side comparison, go
      back to the{" "}
      <a href="/registry" class="text-text underline hover:text-accent transition-colors">
        full registry
      </a>{" "}
      or open the{" "}
      <a href={categoryPath} class="text-text underline hover:text-accent transition-colors">
        {categoryLabel.toLowerCase()} view
      </a>
      . You can also jump straight to{" "}
      <a
        href={`/registry#${getBenchmarkAnchorId(benchmark.name)}`}
        class="text-text underline hover:text-accent transition-colors"
      >
        this benchmark in the master registry list
      </a>
      .
    </p>
  </section>
</Layout>
