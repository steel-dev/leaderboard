---
import Layout from "../layouts/Layout.astro";
import BenchmarkRegistry from "../components/BenchmarkRegistry.astro";
---

<Layout title="Agent Benchmark Registry | Steel.dev">
  <div class="w-full max-w-4xl">
    <div class="mb-8">
      <div class="flex flex-col gap-4">
        <div class="flex flex-col gap-1">
          <h1 class="text-xl md:text-2xl font-sans tracking-tight mb-0">
            Steel.dev<span class="text-accent">®</span>
          </h1>
          <h2 class="text-2xl md:text-4xl font-sans tracking-tight text-text">
            Agent Benchmark Registry
          </h2>
        </div>
        <p class="text-left font-sans md:text-lg">
          A reference index of AI agent benchmarks covering web navigation, deep research, general
          reasoning, and desktop control.
        </p>
      </div>
    </div>
  </div>

  <div class="w-full mt-8">
    <BenchmarkRegistry />
  </div>
</Layout>