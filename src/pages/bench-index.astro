---
import Layout from "../layouts/Layout.astro";
import BenchmarkIndex from "../components/BenchmarkIndex.astro";
---

<Layout title="Benchmark Index | Steel.dev">
  <div class="w-full max-w-4xl">
    <div class="mb-8">
      <div class="flex flex-col gap-4">
        <div class="flex flex-col gap-1">
          <h1 class="text-xl md:text-2xl font-sans tracking-tight mb-0">
            Steel.dev<span class="text-accent">®</span>
          </h1>
          <h2 class="text-2xl md:text-4xl font-sans tracking-tight text-text">
            Benchmark Index
          </h2>
        </div>
        <p class="text-left font-sans md:text-lg">
          All known AI agent benchmark results in one place. Filter by category, benchmark, or search by agent name.
        </p>
      </div>
    </div>
  </div>

  <div class="w-full mt-8">
    <BenchmarkIndex />
  </div>
</Layout>