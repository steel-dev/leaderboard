---
import type { BenchmarkResultRow, BenchmarkScope } from "../lib/benchmark-hub";
import { benchmarkScopeLabels } from "../lib/benchmark-hub";

interface Props {
  rows: BenchmarkResultRow[];
  scope: BenchmarkScope;
  heading?: string;
}

const { rows, scope, heading = "Leaderboard" } = Astro.props;
---

<section class="table-shell w-full">
  <div class="lb-module-head flex items-center justify-between gap-3 px-4 py-3">
    <h2 class="m-0 text-sm font-semibold text-[var(--color-text-strong)]">{heading}</h2>
    <span class="badge">{benchmarkScopeLabels[scope]} scope</span>
  </div>
  <div class="overflow-x-auto">
    <table class="min-w-[980px] w-full border-collapse text-sm">
      <thead class="lb-header text-left text-xs uppercase tracking-[0.04em] text-[var(--color-text-muted)]">
        <tr>
          <th class="px-3 py-2 font-semibold">Rank</th>
          <th class="px-3 py-2 font-semibold">System / Submission</th>
          <th class="px-3 py-2 font-semibold">Score</th>
          <th class="px-3 py-2 font-semibold">Organization</th>
          <th class="px-3 py-2 font-semibold">Notes</th>
          <th class="px-3 py-2 font-semibold">Source</th>
        </tr>
      </thead>
      <tbody>
        {rows.map((row) => (
          <tr class="lb-row align-top">
            <td class="px-3 py-3 font-semibold">{row.rank}</td>
            <td class="px-3 py-3 text-[var(--color-text-strong)]">
              <div class="flex flex-wrap items-center gap-2">
                <span>{row.systemName}</span>
                {row.isNew && <span class="badge badge-accent">New</span>}
              </div>
            </td>
            <td class="px-3 py-3 font-semibold">{row.scoreDisplay}</td>
            <td class="px-3 py-3">{row.organization}</td>
            <td class="px-3 py-3 muted">{row.notesShort}</td>
            <td class="px-3 py-3">
              <a href={row.sourceUrl} target="_blank" rel="noopener noreferrer nofollow">
                Source
              </a>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</section>
